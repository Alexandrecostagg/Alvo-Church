rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid);
    }

    function tenantUserExists(orgId) {
      return exists(userDocPath(orgId));
    }

    function tenantUserData(orgId) {
      return get(userDocPath(orgId)).data;
    }

    function isTenantMember(orgId) {
      return signedIn()
        && tenantUserExists(orgId)
        && tenantUserData(orgId).organizationId == orgId
        && tenantUserData(orgId).isActive == true;
    }

    function isTenantAdmin(orgId) {
      return isTenantMember(orgId)
        && tenantUserData(orgId).roles.hasAny([
          "super_admin",
          "church_admin",
          "pastor",
          "secretary"
        ]);
    }

    match /organizations/{orgId}/users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.organizationId == orgId
        && request.resource.data.isActive == true;

      allow read: if signedIn() && (request.auth.uid == userId || isTenantAdmin(orgId));
      allow update: if signedIn() && (request.auth.uid == userId || isTenantAdmin(orgId));
      allow delete: if isTenantAdmin(orgId);
    }

    match /organizations/{orgId}/settings/{documentId} {
      allow read: if isTenantMember(orgId);
      allow write: if isTenantAdmin(orgId);
    }

    match /organizations/{orgId}/{document=**} {
      allow read: if isTenantMember(orgId);
      allow write: if isTenantAdmin(orgId);
    }
  }
}
